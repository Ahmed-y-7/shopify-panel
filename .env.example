# Copy to .env and fill in — never commit .env
SHOPIFY_STORE=your-store.myshopify.com

# Dev Dashboard app (2026+): Client ID + Secret, exchanged for a token automatically
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=shpss_...

# OR a legacy admin custom-app token (pre-2026 apps only) — takes priority if set
#SHOPIFY_TOKEN=shpat_...
